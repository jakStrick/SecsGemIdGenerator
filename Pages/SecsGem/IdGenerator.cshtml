

@page "/secsgem/id-generator"
@model Solstice.Pages.SecsGem.IdGeneratorModel
@{ ViewData["Title"] = "SECS/GEM ID Generator"; }

<h1 class="mb-3">SECS/GEM ID Generator — Solstice</h1>
<p class="text-muted">
  Generates a CSV master list of all SEMI-standard IDs (E5/E30/E37/E40/E87/E90/E94/E116)
  for the Solstice tool. Adjust ranges and topology, preview, then download.
</p>

<form method="post">
  <div class="row g-3">
    <div class="col-md-3">
      <label class="form-label">Load Ports</label>
      <input class="form-control" type="number" min="1" max="4"
             asp-for="Config.LoadPortCount" />
    </div>
    <div class="col-md-3">
      <label class="form-label">Process Chambers</label>
      <input class="form-control" type="number" min="1" max="8"
             asp-for="Config.ProcessChamberCount" />
    </div>
    <div class="col-md-3">
      <label class="form-label">SVID Start (System)</label>
      <input class="form-control" type="number" asp-for="Config.SvidSystemStart" />
    </div>
    <div class="col-md-3">
      <label class="form-label">ECID Start</label>
      <input class="form-control" type="number" asp-for="Config.EcidStart" />
    </div>
    <div class="col-md-3">
      <label class="form-label">CEID Start</label>
      <input class="form-control" type="number" asp-for="Config.CeidStart" />
    </div>
    <div class="col-md-3">
      <label class="form-label">ALID Start</label>
      <input class="form-control" type="number" asp-for="Config.AlidStart" />
    </div>
    <div class="col-md-3">
      <label class="form-label">DVID Start</label>
      <input class="form-control" type="number" asp-for="Config.DvidStart" />
    </div>
    <div class="col-md-3">
      <label class="form-label">RPTID Start</label>
      <input class="form-control" type="number" asp-for="Config.RptidStart" />
    </div>
  </div>

  <div class="mt-3 d-flex flex-wrap gap-2">
      <button class="btn btn-outline-primary"  formaction="?handler=Preview">
          <i class="bi bi-eye me-1"></i>Preview
      </button>
      <button class="btn btn-primary"          formaction="?handler=Download">
          <i class="bi bi-file-zip me-1"></i>Download CSVs (ZIP)
      </button>
      <button class="btn btn-success"          formaction="?handler=DownloadJson">
          <i class="bi bi-filetype-json me-1"></i>Download JSON
      </button>
      <button class="btn btn-warning text-dark" formaction="?handler=FillMissing"
              title="Assign IDs to any entries that currently have no IdNumber">
          <i class="bi bi-lightning-fill me-1"></i>Calculate Missing IDs
      </button>
      <button class="btn btn-outline-danger"   formaction="?handler=ClearIds"
              onclick="return confirm('Clear all assigned IDs? They will be regenerated from the starting positions.')"
              title="Null out all IdNumbers so they can be reassigned from scratch">
          <i class="bi bi-x-circle me-1"></i>Clear All IDs
      </button>
  </div>

  @if (Model.FilledCount > 0)
  {
      <div class="alert alert-warning mt-3 mb-0 py-2">
          <i class="bi bi-lightning-fill me-1"></i>
          <strong>@Model.FilledCount</strong> missing ID(s) were assigned.
          Review the preview below, then download.
      </div>
  }
  @if (Model.ClearedCount > 0)
  {
      <div class="alert alert-info mt-3 mb-0 py-2">
          <i class="bi bi-x-circle me-1"></i>
          <strong>@Model.ClearedCount</strong> ID(s) cleared — all IdNumber values are now blank.
          Download now to export with blank IDs, or click <strong>Calculate Missing IDs</strong> to reassign.
      </div>
  }
</form>

@if (Model.Preview is not null)
{
    <hr />
    <h2>Preview — @Model.Preview.Count rows</h2>
    <div class="table-responsive" style="max-height:60vh;">
      <table class="table table-sm table-striped">
        <thead><tr>
          <th>IdType</th><th>IdNumber</th><th>Name</th><th>Description</th>
          <th>DataType</th><th>Units</th><th>DefaultValue</th>
          <th>MinValue</th><th>MaxValue</th><th>SemiStandard</th>
          <th>Subsystem</th><th>ReportableInDvvalList</th><th>Notes</th>
        </tr></thead>
        <tbody>
        @foreach (var r in Model.Preview)
        {
          <tr>
            <td>@r.IdType</td>
            <td>@r.IdNumber</td>
            <td><code>@r.Name</code></td>
            <td>@r.Description</td>
            <td>@r.DataType</td>
            <td>@r.Units</td>
            <td>@r.DefaultValue</td>
            <td>@r.MinValue</td>
            <td>@r.MaxValue</td>
            <td>@r.SemiStandard</td>
            <td>@r.Subsystem</td>
            <td>@(r.ReportableInDvvalList ? "true" : "false")</td>
            <td>@r.Notes</td>
          </tr>
        }
        </tbody>
      </table>
    </div>
}

#endregion
